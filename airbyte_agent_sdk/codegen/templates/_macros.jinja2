{# Shared macros for connector documentation templates #}

{# Format action name for display (e.g., "api_search" -> "API Search") #}
{% macro format_action(action) -%}
{{ action.replace('_', ' ')|title|replace('Api ', 'API ') }}
{%- endmacro %}

{# Generate anchor slug (e.g., "customers", "api_search" -> "customers-api-search") #}
{% macro anchor(entity, action) -%}
{{ entity.replace('_', '-')|lower }}-{{ action.replace('_', '-')|lower }}
{%- endmacro %}

{% macro supported_entities_actions_table(entities_grouped, reference_path=None, search_schemas=None) -%}
| Entity | Actions |
|--------|---------|
{% for entity, operations in entities_grouped.items() -%}
| {{ entity.replace('_', ' ')|title }} | {% for op in operations %}{% if reference_path %}[{{ format_action(op.action) }}]({{ reference_path }}#{{ entity.replace('_', '-')|lower }}-{{ op.action|lower }}){% else %}[{{ format_action(op.action) }}](#{{ entity.replace('_', '-')|lower }}-{{ op.action|lower }}){% endif %}{{ ", " if not loop.last else "" }}{% endfor %}{% if search_schemas and entity in search_schemas %}, {% if reference_path %}[{{ format_action("context_store_search") }}]({{ reference_path }}#{{ entity.replace('_', '-')|lower }}-context-store-search){% else %}[{{ format_action("context_store_search") }}](#{{ entity.replace('_', '-')|lower }}-context-store-search){% endif %}{% endif %} |
{% endfor -%}
{%- endmacro %}

