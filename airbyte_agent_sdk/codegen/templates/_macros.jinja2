async for chunk in {{ connector_var }}.{{ op.entity }}.{{ op.action }}(
{%- if not example_params -%}
):
{%- else %}
{% for param in example_params %}
    {{ param.python_name }}={{ param.example_value }}{{ "," if not loop.last else "" }}
{%- endfor %}
):
{%- endif %}
{% if include_download_comment -%}
    # Process each chunk (e.g., write to file)
{% endif %}    file.write(chunk)
{%- else -%}
{%- if assign_to %}{{ assign_to }} = {% endif -%}
await {{ connector_var }}.{{ op.entity }}.{{ op.action }}({% if not example_params %}){% else %}{{ "\n" }}{% for param in example_params %}
    {{ param.python_name }}={{ param.example_value }}{{ "," if not loop.last else "" }}
{% endfor %}{{ ")" }}{% endif %}
{%- endif %}
