{# Emit multi-framework usage code blocks for a connector.
   Each block gets a `title` attribute so Docusaurus remark plugin can wrap them in tabs.
   On GitHub, all three blocks render sequentially with bold labels.

   Args:
     class_name: Connector class name (e.g., "StripeConnector")
     connector_name: Snake-case connector name (e.g., "stripe")
     package_name: Full package path (e.g., "airbyte_agent_sdk.connectors.stripe")
     connector_init_lines: Pre-rendered connector initialization lines (imports + constructor)
#}
{% macro framework_usage_blocks(class_name, connector_name, package_name, connector_init_lines) %}
**Pydantic AI**

```python title="Pydantic AI"
from pydantic_ai import Agent
{{ connector_init_lines }}

agent = Agent("openai:gpt-4o")

@agent.tool_plain
@{{ class_name }}.tool_utils
async def {{ connector_name | snake_case }}_execute(entity: str, action: str, params: dict | None = None):
    return await connector.execute(entity, action, params or {})
```

**LangChain**

```python title="LangChain"
from langchain_core.tools import tool
{{ connector_init_lines }}

@tool
@{{ class_name }}.tool_utils
async def {{ connector_name | snake_case }}_execute(entity: str, action: str, params: dict | None = None):
    """Execute {{ connector_name | title }} connector operations."""
    result = await connector.execute(entity, action, params or {})
    # connector.execute returns a Pydantic envelope for typed actions; fall back to raw data otherwise.
    return result.model_dump(mode="json") if hasattr(result, "model_dump") else result
```

**OpenAI Agents**

```python title="OpenAI Agents"
from agents import Agent, function_tool
{{ connector_init_lines }}

# strict_mode=False because `params: dict` is permissive and the default strict
# JSON schema rejects objects with additionalProperties.
@function_tool(strict_mode=False)
@{{ class_name }}.tool_utils(framework="openai_agents")
async def {{ connector_name | snake_case }}_execute(entity: str, action: str, params: dict | None = None):
    """Execute {{ connector_name | title }} connector operations."""
    result = await connector.execute(entity, action, params or {})
    return result.model_dump(mode="json") if hasattr(result, "model_dump") else result

agent = Agent(name="{{ connector_name | title }} Assistant", tools=[{{ connector_name | snake_case }}_execute])
```

**FastMCP**

```python title="FastMCP"
from fastmcp import FastMCP
{{ connector_init_lines }}

mcp = FastMCP("{{ connector_name | title }} Agent")

@mcp.tool
@{{ class_name }}.tool_utils
async def {{ connector_name | snake_case }}_execute(entity: str, action: str, params: dict | None = None):
    """Execute {{ connector_name | title }} connector operations."""
    result = await connector.execute(entity, action, params or {})
    return result.model_dump(mode="json") if hasattr(result, "model_dump") else result
```
